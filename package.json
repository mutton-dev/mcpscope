{
  "name": "mcpscope",
  "version": "0.1.0",
  "description": "Terminal-first MCP server debugger/inspector TUI",
  "type": "module",
  "bin": {
    "mcpscope": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
