{
  "name": "mcpscope",
  "version": "0.1.0",
  "description": "Terminal-first MCP server debugger/inspector TUI",
  "type": "module",
  "bin": { "mcpscope": "dist/index.js" },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": ["dist"],
  "dependencies": {
    "ink": "^5.0.0",
    "react": "^18.0.0",
    "@types/react": "^18.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^9.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/better-sqlite3": "^7.0.0"
  },
  "engines": { "node": ">=20" }
}
